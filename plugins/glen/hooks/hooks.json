{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "glen session-start --agent codex" }] }
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "glen ingest --agent codex" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "glen ingest --agent codex" }] }
    ],
    "PostToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "glen pr-link --agent codex" }] }
    ]
  }
}
